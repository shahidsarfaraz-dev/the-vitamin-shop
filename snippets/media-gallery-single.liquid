<media-gallery class="product__column-sticky">
  <slider-component class="slider-mobile-gutter">
    <div class="product-media-container media-type-image media-fit-contain global-media-settings gradient constrain-height">
         {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
          {%- endcase -%}
         {%- endfor -%}
      <div class="product__media media media--transparent">
          <div class="product_main-image">
              <img
                src="{{ product.featured_image | image_url: width: 600, format: 'webp', quality: 80 }}"
                srcset="
                  {{ product.featured_image | image_url: width: 300, format: 'webp', quality: 70 }} 300w,
                  {{ product.featured_image | image_url: width: 600, format: 'webp', quality: 80 }} 600w,
                  {{ product.featured_image | image_url: width: 900, format: 'webp', quality: 80 }} 900w
                "
                sizes="(max-width: 600px) 100vw, 600px"
                alt="{{ product.title | escape }}"
                width="600"
                height="600"
                decoding="async"
              >
          </div>
      </div>
    </div>
  </slider-component>
</media-gallery>