{% doc %}
  @prompt
    A heading with an animated glowing effect
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-heading-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-glow-heading__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-glow-heading__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
    position: relative;
    display: inline-block;
    text-shadow: 
      0 0 {{ block.settings.glow_blur }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_blur | times: 1.5 }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_blur | times: 2 }}px {{ block.settings.glow_color }};
    animation: ai-glow-pulse-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease-in-out infinite;
  }

  @keyframes ai-glow-pulse-{{ ai_gen_id }} {
    0%, 100% {
      text-shadow: 
        0 0 {{ block.settings.glow_blur }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_blur | times: 1.5 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_blur | times: 2 }}px {{ block.settings.glow_color }};
      opacity: 1;
    }
    50% {
      text-shadow: 
        0 0 {{ block.settings.glow_blur | times: 1.5 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_blur | times: 2.5 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_blur | times: 3.5 }}px {{ block.settings.glow_color }};
      opacity: {{ block.settings.glow_intensity }};
    }
  }

  @media screen and (max-width: 749px) {
    .ai-glow-heading__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.7);
    }
  }
{% endstyle %}

<glow-heading-{{ ai_gen_id }} class="ai-glow-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-glow-heading__container-{{ ai_gen_id }}">
    {% if block.settings.heading_tag == 'h1' %}
      <h1 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h1>
    {% elsif block.settings.heading_tag == 'h2' %}
      <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
    {% elsif block.settings.heading_tag == 'h3' %}
      <h3 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h3>
    {% elsif block.settings.heading_tag == 'h4' %}
      <h4 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h4>
    {% elsif block.settings.heading_tag == 'h5' %}
      <h5 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h5>
    {% else %}
      <h6 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h6>
    {% endif %}
  </div>
</glow-heading-{{ ai_gen_id }}>

<script>
  (function() {
    class GlowHeading{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('glow-heading-{{ ai_gen_id }}', GlowHeading{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Glow heading",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Glowing Heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#f77c27"
    },
    {
      "type": "range",
      "id": "glow_blur",
      "label": "Glow blur",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Glow intensity",
      "min": 0.5,
      "max": 1,
      "step": 0.1,
      "default": 0.9
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "s",
      "default": 2
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Glow heading"
    }
  ]
}
{% endschema %}
