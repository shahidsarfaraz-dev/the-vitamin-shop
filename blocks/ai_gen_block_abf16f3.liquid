{% doc %}
  @prompt
    Create a popup that displays immediately when the favorites page loads, showing a warning message. The popup should be customizable with editable warning text, adjustable styling (colors, fonts, size), and include a close button so customers can dismiss it.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-warning-popup-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-warning-popup-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-warning-popup-container-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.popup_background_color }};
    border-radius: {{ block.settings.popup_border_radius }}px;
    padding: {{ block.settings.popup_padding }}px;
    max-width: {{ block.settings.popup_max_width }}px;
    width: 90%;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    transform: scale(0.9);
    transition: transform 0.3s ease;
  }

  .ai-warning-popup-overlay-{{ ai_gen_id }}.active .ai-warning-popup-container-{{ ai_gen_id }} {
    transform: scale(1);
  }

  .ai-warning-popup-header-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: {{ block.settings.content_spacing }}px;
  }

  .ai-warning-popup-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-right: 16px;
    color: {{ block.settings.icon_color }};
  }

  .ai-warning-popup-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: {{ block.settings.close_button_color }};
    opacity: 0.7;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .ai-warning-popup-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-warning-popup-close-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-warning-popup-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-warning-popup-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.content_spacing }}px;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
  }

  .ai-warning-popup-message-{{ ai_gen_id }} {
    font-size: {{ block.settings.message_font_size }}px;
    color: {{ block.settings.message_color }};
    line-height: 1.6;
    font-family: {{ block.settings.message_font.family }}, {{ block.settings.message_font.fallback_families }};
    font-weight: {{ block.settings.message_font.weight }};
  }

  .ai-warning-popup-message-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-warning-popup-message-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-warning-popup-container-{{ ai_gen_id }} {
      padding: {{ block.settings.popup_padding | times: 0.7 }}px;
    }

    .ai-warning-popup-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-warning-popup-message-{{ ai_gen_id }} {
      font-size: {{ block.settings.message_font_size | times: 0.9 }}px;
    }

    .ai-warning-popup-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<warning-popup-{{ ai_gen_id }} class="ai-warning-popup-overlay-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-warning-popup-container-{{ ai_gen_id }}">
    <div class="ai-warning-popup-header-{{ ai_gen_id }}">
      {% if block.settings.show_icon %}
        <svg class="ai-warning-popup-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
      {% endif %}
      <div class="ai-warning-popup-content-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-warning-popup-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.message != blank %}
          <div class="ai-warning-popup-message-{{ ai_gen_id }}">{{ block.settings.message }}</div>
        {% endif %}
      </div>
      <button class="ai-warning-popup-close-{{ ai_gen_id }}" aria-label="Close warning popup">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</warning-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class WarningPopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.closeButton = this.querySelector('.ai-warning-popup-close-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.showPopup();
        this.setupEventListeners();
      }

      showPopup() {
        setTimeout(() => {
          this.classList.add('active');
        }, {{ block.settings.delay_seconds | times: 1000 }});
      }

      setupEventListeners() {
        this.closeButton.addEventListener('click', () => {
          this.closePopup();
        });

        this.addEventListener('click', (event) => {
          if (event.target === this) {
            this.closePopup();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && this.classList.contains('active')) {
            this.closePopup();
          }
        });
      }

      closePopup() {
        this.classList.remove('active');
      }
    }

    customElements.define('warning-popup-{{ ai_gen_id }}', WarningPopup{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Warning popup",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Important Notice"
    },
    {
      "type": "richtext",
      "id": "message",
      "label": "Warning message",
      "default": "<p>Please be aware that this page contains important information about your favorites. Make sure to review all items carefully.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show warning icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Popup style"
    },
    {
      "type": "range",
      "id": "popup_max_width",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 500
    },
    {
      "type": "range",
      "id": "popup_padding",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "popup_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "color",
      "id": "popup_background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
      "default": 0.5
    },
    {
      "type": "range",
      "id": "content_spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Content spacing",
      "default": 16
    },
    {
      "type": "header",
      "content": "Title style"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Message style"
    },
    {
      "type": "font_picker",
      "id": "message_font",
      "label": "Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "message_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "color",
      "id": "message_color",
      "label": "Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 24,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Icon size",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#f77c27"
    },
    {
      "type": "color",
      "id": "close_button_color",
      "label": "Close button color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "label": "Display delay",
      "unit": "s",
      "default": 0.5
    }
  ],
  "presets": [
    {
      "name": "Warning popup"
    }
  ]
}
{% endschema %}
