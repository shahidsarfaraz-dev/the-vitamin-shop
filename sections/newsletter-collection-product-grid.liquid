{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{{ 'component-newsletter-collection-product-grid.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>
{%- assign used_line_drives = 0 %}
{%- assign should_break = false %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding page-width collection-grid-wrapper newsletter-collection-product-grid">
  <div class="collection-grid-main-content">
    <div class="product-grid-container" id="ProductGridContainer">
      {%- if collection.products.size == 0 -%}
        <div class="collection collection--empty" id="product-grid" data-id="{{ section.id }}">
          <div class="loading-overlay gradient"></div>
          <div class="title-wrapper center">
            <h2 class="title title--primary">
              {{ 'sections.collection_template.empty' | t -}}
              <br>
              {{
                'sections.collection_template.use_fewer_filters_html'
                | t: link: collection.url, class: 'underlined-link link'
              }}
            </h2>
          </div>
        </div>
      {%- else -%}
        <div class="collection">
          <div class="loading-overlay gradient"></div>
          <ul
            data-id="{{ section.id }}"
            class="
              product-grid-id
              grid product-grid grid--1-col-tablet-down
              grid--{{ section.settings.columns_desktop }}-col-desktop
            "
          >
            {%- for product in collection.products -%}
              {%- for line_drive in collection.metafields.custom.line_drives.value %}
                {%- if forloop.index0 < used_line_drives %}
                  {% continue %}
                {% endif %}
                {% for line_drive_product in line_drive.products.value %}
                  {% if line_drive_product.id == product.id %}
                    <li class="line-drive-container">
                      <section class="line-drive" style="background-color: {{- line_drive.color }}">
                        <h2>{{- line_drive.title }}</h2>
                        {% if line_drive.mobile_image != empty
                          and line_drive.mobile_image != null
                          and line_drive.mobile_image != ''
                        %}
                          <div class="d-block d-md-none mb-2">
                            {{- line_drive.mobile_image | image_url: width: 414 | image_tag }}
                          </div>
                        {% endif %}
                        {% if line_drive.image != empty and line_drive.image != null and line_drive.image != '' %}
                          <div class="d-none d-md-block mb-2">
                            {{- line_drive.image | image_url: width: 1492 | image_tag }}
                          </div>
                        {% endif %}
                        <ul class="line-drive-products line-drive-products-{{- line_drive.columns }}-columns">
                          {%- for ldp in line_drive.products.value %}
                            <li class="line-drive-product">
                              {% render 'simple-product',
                                card_product: ldp,
                                media_aspect_ratio: section.settings.image_ratio,
                                show_secondary_image: section.settings.show_secondary_image,
                                show_vendor: false,
                                show_rating: false,
                                lazy_load: false,
                                show_quick_add: true,
                                section_id: section.id
                              %}
                            </li>
                          {% endfor %}
                        </ul>
                      </section>
                    </li>
                    {% assign used_line_drives = used_line_drives | plus: 1 %}
                    {% assign should_break = true %}
                    {% break %}
                  {% endif %}
                {% endfor %}
                {% if should_break %}
                  {% break %}
                {% endif %}
              {% endfor %}
              {% if should_break %}
                {% assign should_break = false %}
                {% continue %}
              {% endif %}
              {% assign lazy_load = false %}
              {%- if forloop.index > 2 -%}
                {%- assign lazy_load = true -%}
              {%- endif -%}
              <li class="grid__item">
                {% render 'card-product',
                  card_product: product,
                  show_vendor: false,
                  show_rating: true,
                  lazy_load: lazy_load,
                  show_quick_add: true,
                  section_id: section.id
                %}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Newsletter product grid",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header_mobile.content"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}