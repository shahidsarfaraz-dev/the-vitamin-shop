                    </summary>
                  </details>
                </header-drawer>
              {%- endif -%}              
            </div>
            
          </div>
          <div class="header-top-search">

            <div class="header-mobile-menu-icons">
              <ul>
                <li><a href="/collections/sale/"><img src="{{ 'mobile-menu-gift-card.svg' | asset_url }}"/></a></li>
                <li><a href="/pages/favourites/" class="header-mobile-menu-icons__favourites"><img src="{{ 'mobile-menu-favourites.svg' | asset_url }}"/> {% if customer.metafields.custom.wishlist %}<span class="cart-item-count">{{ customer.metafields.custom.wishlist.value | size }}</span>{% endif %}</a></li>
                <li><a href="tel:18883861211"><img src="{{ 'mobile-menu-call.svg' | asset_url }}"/></a></li>
                <li><a href="/pages/flyers/"><img src="{{ 'mobile-menu-flyer.svg' | asset_url }}"/></a></li>
                <li><a href="/pages/coupons/"><img src="{{ 'mobile-menu-coupon.svg' | asset_url }}"/></a></li>
              </ul>
            </div>
            
            <div class="header-search">

            {%- if settings.predictive_search_enabled -%}
              <predictive-search class="search-modal__form" data-loading-text="{{ 'accessibility.loading' | t }}">
            {%- else -%}
              <search-form class="search-modal__form">
            {%- endif -%}
                <form action="{{ routes.search_url }}" method="get" role="search" class="search">
                  <div class="field">
                    <input class="search__input field__input"
                      id="Search-In-Modal"
                      type="search"
                      name="q"
                      value="{{ search.terms | escape }}"
                      placeholder="Search our products..."
