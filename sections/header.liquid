                <li class="header-option-mobile"><a class="header-option-cart" id="cart-icon-mobile" role="button" aria-haspopup="dialog"><img src="{{ 'cart.svg' | asset_url }}"></a> <span class="cart-item-count mobile-only{% if cart.item_count == 0 %} visibility-hidden{% endif %}" data-ajax-cart-section>{{ cart.item_count }}</span></li>
                <li class="header-option-mobile"><a class="header-option-account" href="/account/"><img src="{{ 'user-dark.svg' | asset_url }}"></a></li>
              </ul>
