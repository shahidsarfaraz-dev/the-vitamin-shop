                  <header-menu>
                    {% assign parent_link_title = link.title | downcase |  replace: " ", "-" | replace: "&", "" %}
                    {% assign parent_link_slug = parent_link_title | replace: "--", "-" %}            
                    {% assign collection_title = link.title | downcase |  replace: " ", "-" | replace: "&", "" %}
                    {% assign collection_slug = collection_title | replace: "--", "-" %}
                    {% assign collection = collections[collection_slug] %}
                    {% assign navigation_image = collection.metafields.custom.navigation_image %}
                    <details class="top-level-menu-item parent-menu-item-{{ parent_link_slug }}">
                      <summary class="header__menu-item list-menu__item link focus-inset header__parent-link">
                        <span class="{%- if link.child_active %}header__active-menu-item{% endif %} {% if block.settings.make_button %}menu-style-button{% endif %}"><a href="{{ block.settings.url }}">{{ block.settings.title | escape }}</a></span>
                        {% render 'icon-caret' %}
                      </summary>
                      <ul class="header__submenu menu-list-item-{{ parent_link_slug }} list-menu submenu-container list-menu--disclosure gradient caption-large motion-reduce global-settings-popup" role="list" tabindex="-1">
                        <div class="submenu-scroll-cover"></div>
                        <div class="submenu-child">
                          <div class="header__submenu-wrapper">
                          {% for link in menu_items %}
                            <li class="submenu-item-{{ childlink_slug }}">
                                <a href="{{ link.url }}" open>
                                  <summary class="header__menu-item link link--text list-menu__item focus-inset caption-large">
                                    <span>{{ link.title | escape }}</span>
                                    {% render 'icon-caret' %}
                                  </summary>
                                  <ul class="header__submenu list-menu motion-reduce">
                                    {% for childlink in link.links %}
                                      <li class="submenu-item-{{ grandchildlink_slug }}">
                                        <a href="{{ childlink.url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if childlink.current %} list-menu__item--active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>                                       
                                          {{ childlink.title | escape }}
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                </a>
                            </li>
                          {%- endfor -%}                          
