                Login
              {% endif %}
            </a>
            <div style="position: relative;"><div role="button" aria-haspopup="dialog" id="cart-icon-bubble" class="header-option-cart desktop-only" style="cursor:pointer"><img id="cart-icon-bubble-img" src="{{ 'cart.svg' | asset_url }}"> Cart</div> <span class="cart-item-count desktop-only{% if cart.item_count == 0 %} visibility-hidden{% endif %}" data-ajax-cart-section>{{ cart.item_count }}</span></div>
          </div>
        </div>
      </div>

