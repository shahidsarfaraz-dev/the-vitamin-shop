{{ 'section-header-landing-page.css' | asset_url | stylesheet_tag }}

<div class="header-landing-page page-width">
  <div class="header-landing-page-logo">
    <a href="/"><img src="{{ section.settings.logo | image_url: height: '62x' }}"></a>
  </div>
  <div class="header-landing-page-links">
    <ul>
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'text' %}
          <li class="plain_text">{{ block.settings.text }}</li>
          {% when 'link' %}
          <li class="link"><a href="{{ block.settings.link }}">{{ block.settings.label }}</a></li>
          {% when 'button' %}
          <li><a href="{{ block.settings.link }}" class="button{% if block.settings.custom_class %} {{ block.settings.custom_class }}{% endif %}">{% if block.settings.icon %}<img src="{{ block.settings.icon | image_url: width: '40x' }}"> {% endif %}{{ block.settings.label }}</a></li>
        {% endcase %}
      {% endfor %}
    </ul>
  </div>
</div>

{% schema %}
  {
    "name": "Landing Page Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "Text",
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Text",
            "default": "Lorem Ipsum"
          }
        ]
      },
      {
        "type": "link",
        "name": "Link",
        "settings": [
          {
            "type": "text",
            "id": "label",
            "label": "Link text",
            "default": "Lorem Ipsum"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      },
      {
        "type": "button",
        "name": "Button",
        "settings": [
          {
            "type": "image_picker",
            "id": "icon",
            "label": "Button icon"
          },
          {
            "type": "text",
            "id": "label",
            "label": "Button label",
            "default": "Lorem Ipsum"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Button link"
          },
          {
            "type": "text",
            "id": "custom_class",
            "label": "Custom Class",
            "info": "Add a custom class to your button. (For dev use only)"
          }
        ]
      }
    ],
    "max_blocks": 3,
    "presets": [
      {
        "name": "Landing Page Header",
        "category": "Landing Pages"
      }
    ]
  }
{% endschema %}